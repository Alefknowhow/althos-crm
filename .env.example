# =============================================================================
# ALTHOS CRM — Environment Variables
# Copy this file to .env.local and fill in all values before running locally.
# In production (Vercel), add each variable via:
#   Dashboard → Project → Settings → Environment Variables
# =============================================================================

# --- Supabase -----------------------------------------------------------------
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # anon / public key — safe in browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # service_role — NEVER expose to browser

# --- Resend (transactional email) --------------------------------------------
# Dashboard → API Keys → Create API Key (Full Access)
RESEND_API_KEY=re_...

# Resend webhook signing secret — get from Resend Dashboard → Webhooks →
# endpoint → Signing Secret. Format: "whsec_<base64>" (Svix convention).
# Leave unset to REJECT all Resend webhooks (fail-closed).
# Setup: create endpoint at https://<your-domain>/api/webhooks/resend
# Events to subscribe: email.sent, email.delivered, email.bounced, email.complained
RESEND_WEBHOOK_SECRET=whsec_...

# --- Inngest (background jobs & crons) ----------------------------------------
# Inngest Cloud → Manage → Event Keys + Signing Key
# After first deploy, register endpoint: https://<your-domain>/api/inngest
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-prod-...

# --- Meta / WhatsApp ----------------------------------------------------------
# Meta for Developers → your App → WhatsApp → API Setup
META_WHATSAPP_TOKEN=EAA...
# Any random string you define — used to verify webhook subscription in Meta
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
# App → Settings → Basic → App Secret. Required to verify HMAC signature on
# incoming webhook requests. Leave unset to skip signature verification (insecure).
META_APP_SECRET=...

# --- Web Push (PWA notifications) --------------------------------------------
# Generate ONCE with:
#   node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
# WARNING: if you regenerate these keys, all existing push subscriptions break —
# users will need to re-subscribe. Store the private key securely.
# VAPID_SUBJECT must be "mailto:<email>" or your app URL.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BBUYet_gVADw2WI59qGRozJ1nZk6lH_Z6t07c5oAIFRjPmKEa9VtYzhjaGiOKyYPI1kzu2Te5XZ_n4GEGdAZ4t4
VAPID_PRIVATE_KEY=h5cyU8-BOE5uO9CzbgmhOFpOtnNoE4RnYahUAub7t28
VAPID_SUBJECT=mailto:suporte@althos.io

# --- Cloudflare Turnstile (optional anti-spam) --------------------------------
# dash.cloudflare.com → Turnstile → Add site (type: Managed)
# Leave both unset to disable Turnstile — honeypot + timing + IP rate limit
# will still run on public forms and booking pages.
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITEKEY=
CLOUDFLARE_TURNSTILE_SECRET=
